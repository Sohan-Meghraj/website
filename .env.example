# Copy this file to .env.local and fill in the values

# Public site URL (used in sitemap.xml and robots.txt)
NEXT_PUBLIC_SITE_URL=https://pyriteventures.com

# Calendly booking page URL
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-username

# LinkedIn profile URL for the founder section
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/your-profile

# Optional: webhook URL for lead form submissions (Slack, Discord, Resend, etc.)
# If unset, leads are only logged to the server console.
LEAD_WEBHOOK_URL=
